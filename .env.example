# ===========================================================================
# HireSignal Environment Configuration
# Copy this file to .env and fill in your actual values
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=HireSignal
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# API Authentication
# ---------------------------------------------------------------------------
# Internal API key for endpoint authentication (required)
API_KEY=dev-api-key-change-in-production

# Browser-facing API URL used when Docker builds the frontend image
FRONTEND_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# OpenAI (REQUIRED for embeddings + LLM features)
# Get your key at: https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# OpenRouter (set LLM_PROVIDER=openrouter to use any OpenRouter model)
# Model IDs look like: anthropic/claude-sonnet-4 or google/gemini-2.5-pro
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=HireSignal

# ---------------------------------------------------------------------------
# Anthropic (Optional - for Claude-based synthesis)
# Get your key at: https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ---------------------------------------------------------------------------
# LinkedIn API (Optional - skip if not available)
# Requires LinkedIn Marketing API or third-party service like Proxycurl
# ---------------------------------------------------------------------------
LINKEDIN_API_KEY=
LINKEDIN_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Twitter/X API (Optional - skip if not available)
# Get your tokens at: https://developer.twitter.com/en/portal/dashboard
# ---------------------------------------------------------------------------
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# ---------------------------------------------------------------------------
# Redis Configuration
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Qdrant Vector Database
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=hiresignal_skills

# ---------------------------------------------------------------------------
# Celery Configuration
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ---------------------------------------------------------------------------
# Scoring Weights (must sum to 1.0)
# ---------------------------------------------------------------------------
RESUME_WEIGHT=0.60
SOCIAL_WEIGHT=0.40

# ---------------------------------------------------------------------------
# Cache TTL (seconds)
# ---------------------------------------------------------------------------
CACHE_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# File Upload Limits
# ---------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10

# ---------------------------------------------------------------------------
# LLM Configuration
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_FALLBACK_ENABLED=true
